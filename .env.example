MONGODB_URI=mongodb://localhost:27017/chat-app
PORT=3000
SECRET_KEY=your_secret_key
NODE_ENV=development

# ── Patreon OAuth + Webhooks ──────────────────────────────────────────────────
# Create an app at https://www.patreon.com/portal/registration/register-clients
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
# Must match the redirect URI registered in the Patreon developer portal exactly
PATREON_REDIRECT_URI=https://bambisleep.church/auth/patreon/callback
# Your creator campaign ID (visible in the Patreon API or portal)
PATREON_CAMPAIGN_ID=10683836
# The "secret" returned when you create a webhook via the Patreon API
PATREON_WEBHOOK_SECRET=
# Public base URL of this app (used to build redirect URLs)
APP_BASE_URL=https://bambisleep.church

# ── Patreon Tier IDs ──────────────────────────────────────────────────────────
# Tier IDs are shown in the Patreon developer portal under your campaign tiers
PATREON_TIER_GOOD_GIRL=26542516
PATREON_TIER_PINK_POODLE=23028525
PATREON_TIER_AIRHEAD_BARBIE=27274589